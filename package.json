  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "scripts": {
    "prebuild": "npm run data:consolidateShowLinks",
    "build": "next build",
    "predata:updateShows": "echo '\\nUpdating show data …'",
    "data:updateShows": "node updateShows.mjs",
    "predata:updateShowLinks": "echo '\\nUpdating show links …'",
    "data:updateShowLinks": "node updateShowLinks.mjs",
    "predata:consolidateShowLinks": "echo '\\nConsolidating show links …'",
    "data:consolidateShowLinks": "node consolidateShowLinks.mjs",
    "predev": "npm run data:consolidateShowLinks",
    "dev": "next dev",
    "prelint": "echo '\\nLinting…'",
    "lint": "eslint .",
    "serve": "serve out -p 3000",
    "pretest": "echo '\\nTesting…'",
    "test": "npm run test:e2e",
    "test:e2e": "cypress run --e2e",
    "test:e2e:gui": "cypress open --e2e",
    "test:e2e:withserver": "start-server-and-test dev http://localhost:3000 test:e2e",
    "pretype-check": "npm run data:consolidateShowLinks && echo '\\nType-checking…'",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "markdown-it": "14.1.0",
    "next": "^15",
    "react": "19.2.5",
    "react-dom": "^18.3",
    "sass": "1.94.0"
